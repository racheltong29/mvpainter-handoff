 def reduce_mesh(fname, decimate_type='DECIMATE', target_vertices=5000, smooth_type=1,output_path = None):
+    # Patch (texture-normal eval baseline harness): if bpy is missing, fall back to
+    # trimesh-based decimation. infer_paint calls this with target_vertices=30000;
+    # most meshes in our eval are smaller than that already (e.g. 3K-10K verts), so
+    # decimation is a no-op for them — we just copy fname → output_path. For larger
+    # meshes, trimesh's quadric_decimation produces a similarly reduced mesh.
+    if bpy is None:
+        import shutil, os
+        try:
+            import trimesh
+            mesh = trimesh.load(fname, force='mesh', process=False)
+            if hasattr(mesh, 'vertices') and len(mesh.vertices) > target_vertices:
+                # Quadric decimation. trimesh's API: simplify_quadric_decimation(face_count).
+                target_faces = int(target_vertices * 1.8)  # heuristic: faces ≈ 1.8× verts for triangle meshes
+                try:
+                    mesh = mesh.simplify_quadric_decimation(face_count=target_faces)
+                except Exception:
+                    pass  # if decimation fails, write the original mesh
+            if output_path is None:
+                output_path = fname
+            mesh.export(output_path)
+        except Exception as exc:
+            print(f"[patch reduce_mesh] trimesh fallback failed: {exc}; copying {fname} → {output_path}")
+            if output_path is not None and output_path != fname:
+                shutil.copy2(fname, output_path)
+        return
